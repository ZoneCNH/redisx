# ============================================================
# redisx 环境变量模板
# 复制为 .env 后填入实际值（.env 已在 .gitignore 中排除）
#
# Redis L2 adapter — 真实 Redis 连接完全由环境变量注入
# 文档/日志/Evidence 只记录变量名，不记录真实 host/password/TLS
# ============================================================

# ---- 集成测试开关 ----
# 设为 1 启用真实 Redis 集成测试（默认跳过）
REDISX_INTEGRATION=0
# 设为 1 启用 Redis 持久化恢复集成测试
REDISX_PERSISTENCE_INTEGRATION=0
# 设为 1 使用 Docker Redis 替代真实 Redis（不需要 REDISX_REDIS_*）
REDISX_INTEGRATION_DOCKER=0

# ---- Redis 连接（非敏感，devcontainer/docker-compose 提供默认值）----
REDISX_REDIS_ADDR=redis:6379
REDISX_REDIS_URL=redis://redis:6379/0
REDISX_REDIS_DB=0

# ---- Redis 认证（敏感，只能从本地环境或受控 secret store 注入）----
# 以下变量不在代码/文档/Evidence 中设默认值
# REDISX_REDIS_USERNAME=
# REDISX_REDIS_PASSWORD=

# ---- 持久化恢复测试参数 ----
REDISX_PERSISTENCE_RECOVERY=0
REDISX_PERSISTENCE_EXPECT_EXISTING=0
REDISX_PERSISTENCE_CLEANUP=1
# 以下为持久化测试的 fixture key/value 前缀（可接受默认值）
# REDISX_PERSISTENCE_KEY=redisx:integration:persistence:
# REDISX_PERSISTENCE_VALUE=survives-redis-restart

# ---- Docker Redis 镜像 ----
# REDISX_PERSISTENCE_REDIS_IMAGE=redis:7-alpine
