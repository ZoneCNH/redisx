# ============================================================
# redisx 环境变量模板
# 复制为 .env 后填入实际值
# .env 文件已在 .gitignore 中排除，禁止提交
#
# 密钥命名约定：前缀 REDISX_
# ============================================================

# ---- 实例标识 ----
REDISX_NAME=redisx

# ---- 操作超时（如 5s, 10s, 30s） ----
REDISX_TIMEOUT=5s

# ---- Redis 连接 ----
REDISX_REDIS_ADDR=127.0.0.1:6379
REDISX_REDIS_USERNAME=
REDISX_REDIS_PASSWORD=
REDISX_REDIS_DB=0

# ---- 连接池 ----
REDISX_REDIS_DIAL_TIMEOUT=5s
REDISX_REDIS_READ_TIMEOUT=3s
REDISX_REDIS_WRITE_TIMEOUT=3s
REDISX_REDIS_POOL_SIZE=10
REDISX_REDIS_MIN_IDLE_CONNS=5
REDISX_REDIS_MAX_RETRIES=3

# ---- 可选 Secret（应用级加密密钥） ----
REDISX_SECRET=
