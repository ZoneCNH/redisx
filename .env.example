# ============================================================
# redisx 环境变量模板
# 复制为 .env 后填入实际值
# .env 文件已在 .gitignore 中排除，禁止提交
#
# 密钥命名约定：前缀 FOUNDATIONX_REDISX_
# ============================================================

# ---- 实例标识 ----
FOUNDATIONX_REDISX_NAME=redisx

# ---- 操作超时（如 5s, 10s, 30s） ----
FOUNDATIONX_REDISX_TIMEOUT=5s

# ---- Redis 连接 ----
FOUNDATIONX_REDISX_ADDR=127.0.0.1:6379
FOUNDATIONX_REDISX_USERNAME=
FOUNDATIONX_REDISX_PASSWORD=
FOUNDATIONX_REDISX_DB=0

# ---- 连接池 ----
FOUNDATIONX_REDISX_DIAL_TIMEOUT=5s
FOUNDATIONX_REDISX_READ_TIMEOUT=3s
FOUNDATIONX_REDISX_WRITE_TIMEOUT=3s
FOUNDATIONX_REDISX_POOL_SIZE=10
FOUNDATIONX_REDISX_MIN_IDLE_CONNS=5
FOUNDATIONX_REDISX_MAX_RETRIES=3

# ---- 可选 Secret（应用级加密密钥） ----
FOUNDATIONX_REDISX_SECRET=
