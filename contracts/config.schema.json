{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base Library Config",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 0
    },
    "secret": {
      "type": "string"
    },
    "redis": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "db": {
          "type": "integer",
          "minimum": 0
        },
        "dial_timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "read_timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "write_timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "pool_size": {
          "type": "integer",
          "minimum": 0
        },
        "min_idle_conns": {
          "type": "integer",
          "minimum": 0
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
