{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zonecnh.github.io/redisx/contracts/redisx.config.schema.json",
  "title": "redisx.Options",
  "type": "object",
  "required": ["config"],
  "properties": {
    "config": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 0 },
        "secret": { "type": "string" },
        "redis": {
          "type": "object",
          "properties": {
            "addr": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "db": { "type": "integer", "minimum": 0 },
            "dial_timeout_ms": { "type": "integer", "minimum": 0 },
            "read_timeout_ms": { "type": "integer", "minimum": 0 },
            "write_timeout_ms": { "type": "integer", "minimum": 0 },
            "pool_size": { "type": "integer", "minimum": 0 },
            "min_idle_conns": { "type": "integer", "minimum": 0 },
            "max_retries": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "provider": { "type": "string", "enum": ["in_memory", "redis", "custom"] },
    "metrics": { "type": "string", "enum": ["noop", "custom"] }
  },
  "additionalProperties": false
}
