{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Redisx Config Options",
    "type": "object",
    "required": [
        "name"
    ],
    "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "db": { "type": "integer", "minimum": 0 },
        "tls": { "type": "boolean" },
        "connect_timeout_ms": { "type": "integer", "minimum": 0 },
        "read_timeout_ms": { "type": "integer", "minimum": 0 },
        "write_timeout_ms": { "type": "integer", "minimum": 0 },
        "pool_size": { "type": "integer", "minimum": 0 }
    }
}
